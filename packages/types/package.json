{
  "name": "@xingwu/types",
  "version": "1.0.0",
  "description": "星坞框架共享类型定义",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
